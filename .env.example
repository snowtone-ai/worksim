# WorkSim - 環境変数テンプレート
#
# 使い方:
# 1. このファイルを .env.local という名前でコピーする
# 2. 各 KEY の値を埋める
# 3. .env.local は Git にコミットしない（.gitignore で除外済み）

# ========================================
# Supabase
# ========================================
# 取得手順:
# 1. https://supabase.com にアクセスしてサインアップ（GitHub連携が楽）
# 2. New Project → 適当な名前と強いパスワードを設定（リージョン: Northeast Asia (Tokyo)）
# 3. Settings → API ページで以下をコピー
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# サーバー側専用キー（絶対に公開しない、NEXT_PUBLIC_ プレフィックス禁止）
# Settings → API → service_role key (secret) からコピー
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========================================
# Google OAuth (Supabase 経由で使う)
# ========================================
# 取得手順:
# 1. https://console.cloud.google.com にアクセス
# 2. プロジェクト作成 → APIとサービス → OAuth同意画面（外部、テストユーザー追加）
# 3. 認証情報 → OAuthクライアントID作成 → ウェブアプリケーション
# 4. 承認済みリダイレクトURIに以下を追加:
#    - http://localhost:3000/auth/callback (開発用)
#    - https://<Supabase-Project-Ref>.supabase.co/auth/v1/callback (Supabase用)
#    - https://<your-vercel-domain>/auth/callback (本番用、デプロイ後)
# 5. Supabase Dashboard → Authentication → Providers → Google で
#    Client ID と Client Secret を入力して有効化
#
# 注意：このファイルには Google の Client ID/Secret は書きません
# Supabase Dashboard 側で設定するため、アプリ側からは見えなくてOK

# ========================================
# アプリ設定
# ========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=WorkSim
